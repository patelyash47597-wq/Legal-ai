# ==============================================================
# Database Configuration
# ==============================================================

# Local MySQL (development)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/legal_ai_db

# Production (Render): Auto-configured, but can override here
# DATABASE_URL=postgresql://user:password@host:5432/db_name

# ==============================================================
# AI & Model Services (Required)
# ==============================================================

# Groq API Key - for AI-powered clause explanations
# Get from: https://console.groq.com/api-keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face Token - for InLegalBERT model downloads
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================
# System Configuration
# ==============================================================

# Tesseract OCR path (for advanced PDF processing)
# Linux/Mac: /usr/bin/tesseract
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=/usr/bin/tesseract

# ==============================================================
# Frontend Configuration
# ==============================================================

# API endpoint URL for React frontend
REACT_APP_API_URL=http://localhost:8000
# Production: REACT_APP_API_URL=https://legal-ai-backend-xhht.onrender.com
